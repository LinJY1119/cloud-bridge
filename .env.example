# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

VITE_GEMINI_API_KEY=YOUR_API_KEY
VITE_GEMINI_BASE_URL=

# ---------- Optional: Domestic Big Models (OpenAI Compatible) ----------
# To use an OpenAI-compatible API from a domestic provider (e.g. DeepSeek, Qwen),
# uncomment and set the following variables:

# VITE_AI_PROVIDER=openai
# VITE_OPENAI_API_KEY=YOUR_OPENAI_COMPATIBLE_API_KEY
# VITE_OPENAI_BASE_URL=https://api.deepseek.com/v1
# VITE_OPENAI_MODEL=deepseek-chat